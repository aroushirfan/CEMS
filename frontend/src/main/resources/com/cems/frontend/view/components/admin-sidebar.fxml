<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<VBox spacing="20" minWidth="250" maxWidth="250"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cems.frontend.controllers.components.AdminSidebarController"
      style="-fx-background-color: #FFFFFF; -fx-padding: 30;">
    <Label text="Dashboard" onMouseClicked="#handleDashboard"
            style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #111827;" />
    <Button text="Home" onAction="#handleHome"
            style="-fx-background-color: #f3eeee; -fx-text-fill: black; -fx-font-size: 16;
            -fx-background-radius: 12; -fx-padding: 12 20; -fx-cursor: hand;"
            maxWidth="Infinity"/>
    <Button text="Event Management" onAction="#handleEvents"
            style="-fx-background-color: #f3eeee; -fx-text-fill: black; -fx-font-size: 16;
            -fx-background-radius: 12; -fx-padding: 12 20; -fx-cursor: hand;"
            maxWidth="Infinity"/>
    <Button text="User Management" onAction="#handleUsers"
            style="-fx-background-color: #f3eeee; -fx-text-fill: black; -fx-font-size: 16;
            -fx-background-radius: 12; -fx-padding: 12 20; -fx-cursor: hand;"
            maxWidth="Infinity"/>
    <Region VBox.vgrow="ALWAYS"/>
    <Button text="Logout" onAction="#handleLogout"
            style="-fx-background-color: #f3eeee; -fx-text-fill: black; -fx-font-size: 16; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"
            maxWidth="Infinity"/>
</VBox>