<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="220.0" spacing="0.0" style="-fx-background-color: #E0E0E0; -fx-background-radius: 15; -fx-overflow: hidden;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cems.frontend.controllers.components.EventCardController">

    <StackPane prefHeight="120.0" style="-fx-background-color: #E6E1FF; -fx-background-radius: 15 15 0 0;">
        <children>
        </children>
    </StackPane>

    <VBox spacing="5.0" style="-fx-padding: 10;">
        <Label fx:id="titleLabel" style="-fx-font-size: 14; -fx-font-weight: bold;" text="Career Fair 2026" />
        <Label fx:id="dateTimeLabel" style="-fx-font-size: 11;" text="February 10, 2026 . 12:00 - 16:00" />
        <Label fx:id="locationLabel" style="-fx-font-size: 11;" text="Auditorium" />
        <Label fx:id="spotsLabel" style="-fx-font-size: 11;" text="55 spots left(145/200)" />

        <Region prefHeight="5.0" />
      <HBox spacing="5.0">
         <children>
            <Button fx:id="registerButton" disable="true" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleRegister" style="-fx-background-color: transparent; -fx-text-fill: #424242; -fx-background-radius: 5; -fx-cursor: hand; -fx-border-width: 1; -fx-border-color: #424242; -fx-border-radius: 5;" text="Register" HBox.hgrow="ALWAYS" />
      
              <Button fx:id="learnMoreButton" maxWidth="Infinity" style="-fx-background-color: #424242; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Learn More" HBox.hgrow="ALWAYS" />
         </children>
      </HBox>
    </VBox>
</VBox>
