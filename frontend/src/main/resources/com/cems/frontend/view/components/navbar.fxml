<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.shape.Line?>

<HBox fx:id="navBarHBox" alignment="CENTER_RIGHT" spacing="20.0" style="-fx-padding: 8 20;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cems.frontend.controllers.components.NavbarController">

          <Line endY="30.0" stroke="#E0E0E0" strokeWidth="2.0" />

          <Label fx:id="loginLabel" onMouseClicked="#handleLoginRedirect" style="-fx-font-size: 18; -fx-cursor: hand;" text="%navigation.login" />

          <Button fx:id="signupBtn" onAction="#handleSignupRedirect" style="-fx-background-color: #212121; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 4 25; -fx-font-size: 16; -fx-cursor: hand;" text="%navigation.signup" />
   <Button fx:id="profileBtn" alignment="CENTER" mnemonicParsing="false" onAction="#handleViewProfile" styleClass="profile-btn" stylesheets="@../css/navbar.css" textAlignment="CENTER">
      <graphic>
         <ImageView fitHeight="15.0" fitWidth="15.0" pickOnBounds="true" preserveRatio="true">
            <image>
               <Image url="@../assets/user.png" />
            </image>
            <cursor>
               <Cursor fx:constant="HAND" />
            </cursor>
         </ImageView>
      </graphic>
   </Button>
</HBox>
