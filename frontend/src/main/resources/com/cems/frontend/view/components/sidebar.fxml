<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="sidebarRoot" prefHeight="700.0" prefWidth="240.0" spacing="10.0" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-width: 0 1 0 0;" stylesheets="@../css/sidebar.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cems.frontend.controllers.components.SidebarController">

    <padding>
        <Insets top="30" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <VBox>
            <Label text="CEMS" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1A237E;"/>
            <Label text="logo" style="-fx-font-size: 12; -fx-text-fill: #757575;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="«" style="-fx-font-size: 20; -fx-cursor: hand;"/>
    </HBox>

    <Region prefHeight="40.0" />

    <VBox spacing="8.0">
        <Button fx:id="homeButton" alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#goToHome" styleClass="regular" text="Home" />
        <Button fx:id="allEventsButton" alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#goToAllEvents" styleClass="regular" text="All Events" />
        <Button fx:id="createEventBtn" alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#goToCreateEvent" styleClass="regular" text="Create Event" />
        <Button fx:id="usersButton" alignment="BASELINE_LEFT" maxWidth="Infinity" styleClass="regular" text="Users" />
        <Button fx:id="settingsButton" alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#goToSettings" styleClass="regular" text="Settings" />
        <Button fx:id="englishButton" alignment="BASELINE_LEFT" maxWidth="Infinity" styleClass="regular" text="English" />
    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10 0;">
        <Label text="Dark Mode"/>
        <ToggleButton fx:id="darkModeToggle" text="ON" onAction="#handleDarkMode"
                      style="-fx-background-radius: 15;"/>
    </HBox>

    <Button fx:id="logoutButton" maxWidth="Infinity" onAction="#handleLogout" style="-fx-background-color: #546E7A; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10;" text="Logout" />
</VBox>
