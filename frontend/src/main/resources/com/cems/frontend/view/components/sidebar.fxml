<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="sidebarRoot"
      prefHeight="700" prefWidth="240"
      spacing="10"
      style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-width: 0 1 0 0;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cems.frontend.controllers.components.SidebarController">

    <padding>
        <Insets top="30" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <VBox>
            <Label text="CEMS" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1A237E;"/>
            <Label text="logo" style="-fx-font-size: 12; -fx-text-fill: #757575;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="«" style="-fx-font-size: 20; -fx-cursor: hand;"/>
    </HBox>

    <Region prefHeight="40"/>

    <VBox spacing="8">
        <Button fx:id="homeBtn" text="Home" maxWidth="Infinity"
                alignment="BASELINE_LEFT" onAction="#goToHome"
                styleClass="sidebar-btn"/>

        <Button fx:id="allEventsBtn" text="All Events" maxWidth="Infinity"
                alignment="BASELINE_LEFT" onAction="#goToAllEvents"
                styleClass="sidebar-btn"/>

        <Button fx:id="createEventBtn" text="Create Event" maxWidth="Infinity"
                alignment="BASELINE_LEFT" onAction="#goToCreateEvent"
                styleClass="sidebar-btn"/>

        <Button fx:id="usersBtn" text="Users" maxWidth="Infinity"
                alignment="BASELINE_LEFT" styleClass="sidebar-btn"/>

        <Button fx:id="settingsBtn" text="Settings" maxWidth="Infinity"
                alignment="BASELINE_LEFT" onAction="#goToSettings"
                styleClass="sidebar-btn"/>

        <Button fx:id="languageBtn" text="English" maxWidth="Infinity"
                alignment="BASELINE_LEFT" styleClass="sidebar-btn"/>
    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10 0;">
        <Label text="Dark Mode"/>
        <ToggleButton fx:id="darkModeToggle" text="ON" onAction="#handleDarkMode"
                      style="-fx-background-radius: 15;"/>
    </HBox>

    <Button fx:id="logoutButton" text="Logout" maxWidth="Infinity"
            onAction="#handleLogout"
            style="-fx-background-color: #546E7A; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10;"/>
</VBox>
