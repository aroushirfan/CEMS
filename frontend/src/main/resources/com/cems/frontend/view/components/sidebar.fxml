<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="sidebarRoot" prefHeight="700.0" prefWidth="240.0" spacing="10.0" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-width: 0 1 0 0;" stylesheets="@../css/sidebar.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cems.frontend.controller.components.SidebarController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="30" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <VBox>
            <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1A237E;" text="%sidebar.cems" />
            <Label style="-fx-font-size: 12; -fx-text-fill: #757575;" text="%sidebar.logo" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Label style="-fx-font-size: 20; -fx-cursor: hand;" />
    </HBox>

    <Region prefHeight="40.0" />

    <VBox spacing="8.0">
        <Button fx:id="homeButton" alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#goToHome" styleClass="sidebar-btn" text="%sidebar.home" />
        <Button fx:id="allEventsButton" alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#goToAllEvents" styleClass="sidebar-btn" text="%sidebar.all_events" />
        <Button fx:id="createEventBtn" alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#goToCreateEvent" styleClass="sidebar-btn" text="%sidebar.create_event" />
        <Button fx:id="settingsButton" alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#goToSettings" styleClass="sidebar-btn" text="%sidebar.settings" />
        <Button fx:id="eventManagementBtn" alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#goToEventManagement" styleClass="sidebar-btn" text="%sidebar.event_mgmt" />

        <Button fx:id="userManagementBtn" alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#goToUserManagement" styleClass="sidebar-btn" text="%sidebar.user_mgmt" />
    </VBox>

    <Region VBox.vgrow="ALWAYS" />
   <ComboBox fx:id="languageComboBox" maxWidth="1.7976931348623157E308" onAction="#handleLanguageChange" prefWidth="150.0" promptText="Language" />

    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10 0;">
        <Label text="%sidebar.dark_mode" />
        <ToggleButton fx:id="darkModeToggle" onAction="#handleDarkMode" style="-fx-background-radius: 15;" text="%sidebar.toggle_button.on" />
    </HBox>

    <Button fx:id="logoutButton" maxWidth="Infinity" onAction="#handleLogout" style="-fx-background-color: #546E7A; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10;" text="%sidebar.logout" />
</VBox>
