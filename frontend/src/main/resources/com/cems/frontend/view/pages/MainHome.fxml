<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/24.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cems.frontend.controllers.pages.MainHomeController">

    <children>

        <fx:include source="../components/navbar.fxml" />

        <ScrollPane fx:id="rootScroll"
                    fitToWidth="true"
                    style="-fx-background-color: transparent;"
                    VBox.vgrow="ALWAYS">

            <content>

                <VBox spacing="0">

                    <!-- HERO SECTION -->
                    <StackPane HBox.hgrow="ALWAYS">

                        <children>

                            <VBox spacing="0" HBox.hgrow="ALWAYS">
                                <children>

                                    <ImageView fx:id="heroImage"
                                               fitHeight="320"
                                               preserveRatio="false"
                                               HBox.hgrow="ALWAYS">
                                        <image>
                                            <Image url="@../assets/hero.jpg" />
                                        </image>
                                    </ImageView>

                                    <HBox style="-fx-background-color: #E5E5E5; -fx-padding: 55 0 55 0;"
                                          HBox.hgrow="ALWAYS" />

                                </children>
                            </VBox>


                            <Pane StackPane.alignment="BOTTOM_CENTER" style="-fx-translate-y: 300;-fx-translate-x: 150;">
                                <HBox alignment="CENTER"
                                      spacing="80"
                                      prefWidth="900"
                                      maxWidth="900">

                                    <children>

                                        <VBox alignment="CENTER" spacing="10">
                                            <children>
                                                <ImageView fitHeight="45" preserveRatio="true">
                                                    <image><Image url="@../assets/icons/search.png" /></image>
                                                </ImageView>
                                                <Label text="Discover campus events" />
                                            </children>
                                        </VBox>

                                        <VBox alignment="CENTER" spacing="10">
                                            <children>
                                                <ImageView fitHeight="45" preserveRatio="true">
                                                    <image><Image url="@../assets/icons/list.png" /></image>
                                                </ImageView>
                                                <Label text="Track Attendance" />
                                            </children>
                                        </VBox>

                                        <VBox alignment="CENTER" spacing="10">
                                            <children>
                                                <ImageView fitHeight="45" preserveRatio="true">
                                                    <image><Image url="@../assets/icons/bell.png" /></image>
                                                </ImageView>
                                                <Label text="Event Alerts" />
                                            </children>
                                        </VBox>

                                    </children>

                                </HBox>
                            </Pane>

                        </children>

                    </StackPane>


                    <!-- EVENTS SECTION -->
                    <VBox spacing="30" style="-fx-padding: 20 40 40 40;">
                        <children>

                            <HBox alignment="CENTER_LEFT">
                                <children>
                                    <Label text="Events">
                                        <font><Font size="28" /></font>
                                    </Label>
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="seeAllEventsLink"
                                           onMouseClicked="#goToAllEvents"
                                           style="-fx-text-fill: #1B336F; -fx-font-size:16; -fx-underline: true; -fx-cursor: hand;"
                                           text="see all events" />
                                </children>
                            </HBox>

                            <FlowPane fx:id="eventGrid"
                                      alignment="CENTER"
                                      columnHalignment="CENTER"
                                      rowValignment="CENTER"
                                      hgap="25"
                                      vgap="25"
                                      prefWidth="Infinity" />

                            <!-- VIEW MORE -->
                            <HBox alignment="CENTER">
                                <children>
                                    <Label fx:id="viewMoreLabel"
                                           text="View more"
                                           style="
                           -fx-background-color: #F9F5FF;
                           -fx-text-fill: #1B336F;
                           -fx-font-size: 15;
                           -fx-font-weight: bold;
                           -fx-padding: 12 28 12 28;
                           -fx-background-radius: 8;
                           -fx-border-color: #E8E0FF;
                           -fx-border-radius: 8;
                           -fx-border-width: 1;
                           -fx-letter-spacing: 1px;
                           -fx-cursor: hand;
                       " />
                                </children>
                            </HBox>

                        </children>
                    </VBox>


                </VBox>

            </content>

        </ScrollPane>

    </children>

</VBox>
