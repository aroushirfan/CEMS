<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cems.frontend.controllers.pages.UserManagementController">

    <fx:include source="../components/sidebar.fxml"/>

    <VBox spacing="20" HBox.hgrow="ALWAYS" style="-fx-padding: 20;">
        <fx:include source="../components/navbar.fxml"/>
        <HBox spacing="10">
        <TextField fx:id="searchField"
                   promptText="Search users..."
                   style="-fx-padding: 8; -fx-background-radius: 5;"/>
        </HBox>

        <TableView fx:id="userTable" maxWidth="1100">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="200"/>
                <TableColumn fx:id="emailColumn" text="Email" prefWidth="200"/>
                <TableColumn fx:id="firstNameColumn" text="First Name" prefWidth="150"/>
                <TableColumn fx:id="lastNameColumn" text="Last Name" prefWidth="150"/>
                <TableColumn fx:id="accessLevelColumn" text="Role" prefWidth="100"/>
                <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="300"/>
            </columns>
        </TableView>

    </VBox>
</HBox>